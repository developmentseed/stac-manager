{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "stac-manager",
      "include-component-in-tag": false,
      "extra-files": [
        {
          "type": "json",
          "path": "packages/client/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "yaml",
          "path": "charts/stac-manager/Chart.yaml",
          "jsonpath": "$.version"
        },
        {
          "type": "yaml",
          "path": "charts/stac-manager/Chart.yaml",
          "jsonpath": "$.appVersion"
        }
      ]
    }
  }
}
